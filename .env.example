# ==============================================================================
# CONFIGURACIÓN GLOBAL DEL PROYECTO - LAST MILE LOGISTICS
# ==============================================================================
# Instrucciones: Copia este archivo como '.env' y completa los valores.
# NO subas el archivo '.env' real a GitHub por seguridad.

# ── CAPA DE DATOS (VM3) ───────────────────────────────────────────────────────
# IP PRIVADA de la VM3. Se usa para comunicación interna entre máquinas.
# Cámbiala cada vez que el Lab de AWS se reinicie.
MYSQL_HOST=172.31.XX.XX
POSTGRES_HOST=172.31.XX.XX
MONGO_HOST=172.31.XX.XX

# ── MICROSERVICIO FLOTA (MySQL - Puerto 3306) ─────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=flotadb
MYSQL_USER=flota_user
MYSQL_PASSWORD=flota_pass

# ── MICROSERVICIO PEDIDOS (PostgreSQL - Puerto 5432) ──────────────────────────
POSTGRES_DB=pedidosdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ── MICROSERVICIO EVENTOS (MongoDB - Puerto 27017) ────────────────────────────
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo123
MONGO_DATABASE=eventosdb

# ── CAPA DE ANALÍTICA (AWS S3 & Athena) ───────────────────────────────────────
# Estos datos se obtienen de la consola de AWS (IAM y S3)
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=TU_SECRET_KEY
AWS_REGION=us-east-1
ATHENA_S3_OUTPUT_LOCATION=s3://tu-bucket-athena-resultados/
ATHENA_DATABASE=lastmile_db

# ── CONFIGURACIÓN DEL FRONTEND (Vite) ─────────────────────────────────────────
# ¡CRÍTICO! Debe ser la IP PÚBLICA de la VM1 (Orquestador).
# Si usas 'localhost', tus compañeros no podrán ver los datos desde sus casas.
VITE_API_URL=http://54.XX.XX.XX:8001